[sub_resource type="GDScript" id="GDScript_44qaa"]
resource_name = "PreviewScript"
script/source = "extends Node3D

const CCMeshInstance = preload(\"res://CCMeshInstance.gd\")
const CCCameraPath = preload(\"res://CCCameraPath.gd\")
const CCRoomCamera = preload(\"res://CCRoomCamera.gd\")
const CCWalkMesh = preload(\"res://CCWalkMesh.gd\")

var animPlayer: AnimationPlayer
var isDraggingAnimationSlider := false
var last_gltf = null
var isCombatModel = false

const default_names_combat: Dictionary[String, String] = {
	\"Anim0\": \"DefaultPose\",
	\"Anim1\": \"Idle\",
	\"Anim2\": \"AttackStance\",
	\"Anim3\": \"Approach\",
	\"Anim4\": \"Return\",
	\"Anim5\": \"Hit1\",
	\"Anim6\": \"Hit2\",
	\"Anim7\": \"Hit3\",
	\"Anim8\": \"Dead\",
	\"Anim9\": \"Revive\",
	\"Anim10\": \"IdleHurt\",
	\"Anim11\": \"Dodge\",
	\"Anim12\": \"Block\",
	\"Anim13\": \"CastPrepare\",
	\"Anim14\": \"KnockedDown\",
	\"Anim15\": \"ReturnStart\",
	\"Anim16\": \"ReturnEnd\",
	\"Anim17\": \"ReturnLand\",
	\"Anim18\": \"Cast\",
	\"Anim19\": \"CastChannel\",
	\"Anim20\": \"CastEnd\",
	\"Anim21\": \"Defend\",
}
const default_names_field: Dictionary[String, String] = {
	\"Anim0\": \"DefaultPose\",
	\"Anim1\": \"Idle\",
	\"Anim2\": \"Run\",
	\"Anim3\": \"Walk\",
	\"Anim5\": \"Climb\",
	\"Anim6\": \"TurnRight\",
	\"Anim7\": \"TurnLeft\",
	\"Anim8\": \"SquareUp\",
}

func _ready():
	%AnimationList.item_selected.connect(_animation_selected)
	%AnimationSlider.value_changed.connect(_on_slider_value_changed)
	%AnimationSlider.drag_started.connect(_on_slider_drag_started)
	%AnimationSlider.drag_ended.connect(_on_slider_drag_ended)
	%LoopToggle.toggled.connect(_on_loop_toggled)
	%CastButton.pressed.connect(_on_cast_pressed)
	%PlaybackRateSpinBox.value_changed.connect(_on_playback_rate_changed)
	%ExportGLTFButton.pressed.connect(_on_export_press)
	%GroundToggle.pressed.connect(func(): %Ground.visible = %GroundToggle.button_pressed)
	%SpaceOutToggle.pressed.connect(_on_space_out_toggle)
	%SkyToggle.pressed.connect(_on_sky_toggle)
	%AnimateToggle.pressed.connect(_on_animate_toggle)
	
func _on_sky_toggle():
	var env: Environment = %WorldEnvironment.environment
	if %SkyToggle.button_pressed:
		env.background_mode = Environment.BG_SKY
	else:
		env.background_mode = Environment.BG_COLOR
		env.background_color = Color(0, 0, 0, 1.0)

func loadGltf(gltfBuffer: PackedByteArray, is_combat_model: bool):
	var state = GLTFState.new()
	var doc = GLTFDocument.new()
	LoadTimer.start(\"Parsing gltf\")
	var err = doc.append_from_buffer(gltfBuffer, \"\", state)
	LoadTimer.stop()
	if err == OK:
		last_gltf = gltfBuffer
		isCombatModel = is_combat_model
		# Godot is compressing the textures, is there a way to disable that? They're super tiny already anyway.
		LoadTimer.start(\"Generating scene\")
		var scene = doc.generate_scene(state)
		LoadTimer.stop()
		LoadTimer.start(\"Setting up scene\")
		setScene(scene)
		LoadTimer.stop()
	else:
		print(\"err \", err, \" appending to gltf from buffer\")
		
func _on_export_press():
	var to_export = last_gltf
	var save = func(status: bool, paths: PackedStringArray, _filterIndex: int):
		if status:
			var file = FileAccess.open(paths[0], FileAccess.WRITE)
			if file != null:
				file.store_buffer(to_export)
				file.close()
				%PopupMessage.show_message(\"Exported to \" + paths[0])
	if to_export == null:
		%PopupMessage.show_message(\"[color='red']Nothing to export![/color]\")
	else:
		DisplayServer.file_dialog_show(
			\"Export glTF\", \".\", %Tree.get_selected().get_text(0), false,
			DisplayServer.FILE_DIALOG_MODE_SAVE_FILE, [\"*.gltf\"],
			save
		)
		
func _on_cast_pressed():
	if animPlayer is AnimationPlayer:
		animPlayer.queue(\"Anim13\")
		animPlayer.queue(\"Anim13\")
		animPlayer.queue(\"Anim18\")
		animPlayer.queue(\"Anim19\")
		animPlayer.queue(\"Anim19\")
		animPlayer.queue(\"Anim19\")
		animPlayer.queue(\"Anim20\")
	
func calculateBounds(node: Node = self):
	var aabb = null
	if node is VisualInstance3D:
		aabb = node.get_aabb()
	for child in node.get_children():
		var childAabb = calculateBounds(child)
		if childAabb != null:
			if aabb != null:
				aabb = aabb.merge(childAabb)
			else:
				aabb = childAabb
	if aabb != null and node is Node3D:
		aabb = node.transform * aabb
	return aabb

var originalPositions = {}
func spaceOutChildren(node: Node, spacing = 0.5):
	var x = null
	for child in node.get_children():
		if child is Node3D:
			var bounds = calculateBounds(child)
			if bounds is AABB:
				if x == null:
					x = bounds.end.x
				else:
					child.position.x += x - bounds.position.x
					x += bounds.size.x
				x += spacing
	var totalBounds = calculateBounds(node)
	if totalBounds is AABB:
		for child in node.get_children():
			if child is Node3D:
				child.position.x -= totalBounds.get_center().x

func layoutScene(node):
	originalPositions.clear()
	for child in node.get_children():
		if child is Node3D:
			originalPositions[child] = child.position

	var background = node.find_child(\"Background\", false)
	if background is Node:
		node.remove_child(background)
	spaceOutChildren(node)
	var totalBounds = calculateBounds(node)
	if background is Node:
		node.add_child(background)
		background.set_owner(node)
	if background is Node3D:
		var bgBounds = calculateBounds(background)
		if bgBounds is AABB:
			background.position.y -= bgBounds.position.y
			background.position.x -= bgBounds.get_center().x
			if totalBounds is AABB:
				background.position.z -= 1.0 + bgBounds.end.z - totalBounds.position.z

func _on_space_out_toggle():
	if get_child_count() == 0: return
	var node = get_child(0)
	var shouldSpaceOut = %SpaceOutToggle.button_pressed
	if not shouldSpaceOut:
		for child in node.get_children():
			if child is Node3D and child in originalPositions:
				child.position = originalPositions[child]
	else:
		layoutScene(node)

func _setup_blend_mode(meshInstance: MeshInstance3D):
	var mesh = meshInstance.mesh
	for surface_idx in mesh.get_surface_count():
		var material: StandardMaterial3D = mesh.surface_get_material(surface_idx)
		match material.get_meta(\"extras\") if material.has_meta(\"extras\") else null:
			{\"blend_mode\": \"mix\", ..}:
				pass
			{\"blend_mode\": \"add\", ..}:
				material.blend_mode = BaseMaterial3D.BLEND_MODE_ADD
			{\"blend_mode\": \"subtract\", ..}:
				material.blend_mode = BaseMaterial3D.BLEND_MODE_SUB

func setScene(node: Node):
	for child in get_children():
		remove_child(child)
		child.queue_free()
	for child in %TempControls.get_children():
		child.queue_free()
	for untyped_child in node.find_children(\"\", \"MeshInstance3D\"):
		var child = untyped_child as MeshInstance3D
		_setup_blend_mode(child)
		if child.has_meta(\"extras\") and child.get_meta(\"extras\").has(\"animations\"):
			child.set_script(CCMeshInstance)
		#if child.name.contains(\"WalkMesh\"):
			#child.mesh.surface_get_material(0).no_depth_test = true
	for untyped_child in node.find_children(\"\", \"Node3D\"):
		var child = untyped_child as Node3D
		if child.has_meta(\"extras\") and child.get_meta(\"extras\").has(\"point_pairs\"):
			child.set_script(CCCameraPath)
	var navCamera = node.find_child(\"Room3DCamera\", true, false)
	if navCamera is Camera3D:
		navCamera.set_script(CCRoomCamera)
	var walkMesh = node.find_child(\"*-WalkMesh\", true, false)
	if walkMesh is MeshInstance3D:
		walkMesh.set_script(CCWalkMesh)
	if navCamera != null and walkMesh != null:
		var roomNode = Node3D.new()
		roomNode.name = \"Room\"
		node.add_child(roomNode)
		navCamera.reparent(roomNode, false)
		walkMesh.reparent(roomNode, false)
	add_child(node)
	node.owner = self
	# fixupBlendModes(node)
	var background = node.find_child(\"Background\", false)
	if %SpaceOutToggle.button_pressed:
		layoutScene(node)
	if background is Node:
		for meshInstance in background.find_children(\"\", \"MeshInstance3D\", true, false):
			var mi = meshInstance as MeshInstance3D
			mi.cast_shadow = GeometryInstance3D.SHADOW_CASTING_SETTING_OFF
			
			var check := CheckBox.new()
			check.text = meshInstance.name
			check.button_pressed = true
			%TempControls.add_child(check)
			check.toggled.connect(func(b): mi.visible = b)
	if navCamera is Camera3D:
		var btn := CheckButton.new()
		btn.text = \"Room Camera\"
		%TempControls.add_child(btn)
		btn.toggled.connect(func(b): navCamera.current = b)
		var baseScale = 1.0
		# Hardcoded offset? Authored for 320x240? (psx is 256x224 though...?)
		var offsetX = -160.0
		var offsetY = 120.0
		var zOffset = 0.0
		match navCamera.get_meta(\"extras\"):
			{ \"cameraMystery\":  { \"unknown1\": var unk1, \"unknown2\": var unk2, .. }, .. }:
				baseScale = unk1
				zOffset = -unk2 / 64.0
		for meshInstance in background.find_children(\"\", \"MeshInstance3D\", false, false):
			var mi = meshInstance as MeshInstance3D
			background.remove_child(mi)
			navCamera.add_child(mi)
			print(\"Original z for \", meshInstance.name, \": \", mi.position.z * 625.0)
			mi.position.z = zOffset + mi.position.z * 625.0 / 40.0 # 625.0/40.0 is close to 16 (15.625), relevant?
			mi.scale = Vector3(-mi.position.z, -mi.position.z, -mi.position.z) / baseScale
			mi.position.x = offsetX * mi.scale.x
			mi.position.y = offsetY * mi.scale.y
	if walkMesh is MeshInstance3D:
		%RoomCharacter.walkMesh = walkMesh

	%AnimationList.clear()
	animPlayer = node.find_child(\"AnimationPlayer\")
	if animPlayer is AnimationPlayer:
		var animLibrary = animPlayer.get_animation_library('')
		animPlayer.animation_finished.connect(_on_animation_finished)
		animPlayer.animation_started.connect(_on_animation_started)
		animPlayer.speed_scale = %PlaybackRateSpinBox.value
		animPlayer.deterministic = true
		var anims = Array(animPlayer.get_animation_list())
		anims.sort_custom(func(a: String, b: String): return a.naturalnocasecmp_to(b) < 0)
		for animation in anims:
			var with_hint = animation
			var default_names = default_names_combat if isCombatModel else default_names_field
			if default_names.has(animation):
				with_hint += \" (\" + default_names[animation] + \")\"
			var index = %AnimationList.add_item(with_hint)
			%AnimationList.set_item_metadata(index, animation)
			animLibrary.add_animation(\"LOOPING\" + animation, make_looped_version(animPlayer.get_animation(animation)))

func _animation_selected(index: int) -> void:
	if animPlayer is AnimationPlayer:
		animPlayer.seek(0)
		var toPlay = (\"LOOPING\"  if %LoopToggle.button_pressed else \"\") + %AnimationList.get_item_metadata(index)
		print(\"Playing \" + toPlay)
		animPlayer.play(toPlay)

func _on_play_button_pressed() -> void:
	if animPlayer is AnimationPlayer:
		if animPlayer.is_playing():
			animPlayer.pause()
			#process_mode = Node.PROCESS_MODE_DISABLED
		else:
			animPlayer.play()
			#process_mode = Node.PROCESS_MODE_INHERIT
			
func _on_playback_rate_changed(playbackRate: float) -> void:
	if animPlayer is AnimationPlayer:
		animPlayer.speed_scale = playbackRate

func _on_slider_drag_started() -> void:
	isDraggingAnimationSlider = true
	if animPlayer is AnimationPlayer:
		animPlayer.pause()

func _on_slider_value_changed(value: float) -> void:
	if not isDraggingAnimationSlider: return
	if animPlayer is AnimationPlayer:
		animPlayer.seek(value * animPlayer.current_animation_length, true)

func _on_slider_drag_ended(_changed) -> void:
	isDraggingAnimationSlider = false
	
func _on_animation_started(_animationName) -> void:
	#process_mode = Node.PROCESS_MODE_INHERIT
	pass

func _on_animation_finished(_animationName) -> void:
	#process_mode = Node.PROCESS_MODE_DISABLED
	pass

const KEYFRAME_DURATION = 1.0 / 15.0
func make_looped_version(animation: Animation) -> Animation:
	var new_animation = animation.duplicate_deep(Resource.DEEP_DUPLICATE_ALL)
	# print(\"Making looped version of animation with length: \" + str(new_animation.length))
	if new_animation.length < 0.05: return new_animation
	new_animation.length += KEYFRAME_DURATION
	for track_index in animation.get_track_count():
		var initial_value = new_animation.track_get_key_value(track_index, 0)
		new_animation.track_insert_key(track_index, new_animation.length, initial_value)
	new_animation.loop_mode = Animation.LOOP_LINEAR
	return new_animation
			
func _on_loop_toggled(toggledOn) -> void:
	if animPlayer is AnimationPlayer:
		var animName = animPlayer.assigned_animation
		animName = animName.replace('LOOPING', '')
		var time = animPlayer.current_animation_position
		if toggledOn:
			animPlayer.play(\"LOOPING\" + animName)
		else:
			animPlayer.assigned_animation = animName
		animPlayer.seek(time, true)
	
func _process(_delta: float) -> void:
	if animPlayer is AnimationPlayer and animPlayer.current_animation != &\"\":
		%AnimationSlider.value = float(animPlayer.current_animation_position) / animPlayer.current_animation_length

func _on_animate_toggle():
	process_mode = Node.PROCESS_MODE_INHERIT if %AnimateToggle.button_pressed else Node.PROCESS_MODE_DISABLED
"

