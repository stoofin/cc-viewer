[sub_resource type="GDScript" id="GDScript_is1qn"]
resource_name = "TreeScript"
script/source = "extends Tree

var itemPaths: Dictionary[TreeItem, String] = {}

var cdrom_path = \"../originals-rde/zips/cdrom.dat\"

var converters_list = []

var last_loaded_path := \"\"
var last_loaded_extras := []

var context_menu_for_path = null

const HIGHLIGHT_UGLY = 0 # supported but without texture
const HIGHLIGHT_ANIMATIONS = 1
const HIGHLIGHT_TEXTURE = 2
const HIGHLIGHT_MODEL = 3
const HIGHLIGHT_COLORS = [
	Color(0.9, 0.4, 0.2),
	Color(0.2,0.8, 0.9),
	Color(0.5,1.0, 0.2),
	Color(1.0, 0.9, 0.2)
];
var highlighted_already

var highlight_paths = [
	[\"battle/bg/.+\\\\.prd$\", HIGHLIGHT_MODEL],
	[\"battle/bg/.+\\\\.ctd$\", HIGHLIGHT_UGLY],
	[\"battle/(player|monster)/.+\\\\.obj$\", HIGHLIGHT_MODEL],
	[\"battle/effects/.+\\\\.prd$\", HIGHLIGHT_MODEL],
	[\"battle/effects/.+\\\\.ctd$\", HIGHLIGHT_UGLY],
	[\"battle/wepon/.+\\\\.bin$\", HIGHLIGHT_MODEL],
	[\"battle/wepon/.+\\\\.kmd$\", HIGHLIGHT_UGLY],
	[\"fieldobj/ex/[^/]+\\\\.bin$\", HIGHLIGHT_ANIMATIONS],
	[\"fieldobj/player/[^/]+/[^/]+\\\\.obj$\", HIGHLIGHT_MODEL],
	[\"map/mapbin/[^/]+\\\\.bin$\", HIGHLIGHT_MODEL],
	[\"map/mapbin/[^/]+\\\\.ctd$\", HIGHLIGHT_TEXTURE],
	[\".+\\\\.tim$\", HIGHLIGHT_TEXTURE],
	[\".+\\\\.ltc$\", HIGHLIGHT_TEXTURE],
	[\".+\\\\.ltd$\", HIGHLIGHT_TEXTURE],
	[\"^title.prd$\", HIGHLIGHT_MODEL],
].map(func (a): return [RegEx.create_from_string(\"^(\" + a[0] + \")$\"), a[1]])

const OVERWORLD = 1
const TECH1 = 2
const TECH2 = 3
const TECH3 = 4

func get_most_recent_converter():
	var converters = converters_list.filter(func(path): return FileAccess.file_exists(path))
	converters.sort_custom(func(a, b): return FileAccess.get_modified_time(a) < FileAccess.get_modified_time(b))
	var result = converters.get(converters.size() - 1)
	if result == null:
		push_error(\"No converter binary found!\")
	return result

func _ready():
	%ZipOpenButton.pressed.connect(_on_zip_open_press)
	%TreeContextMenu.id_pressed.connect(_on_context_menu_pressed)
	%TreeContextMenu.add_item(\"Add overworld animations (.bin)\", OVERWORLD)
	%TreeContextMenu.add_separator()
	%TreeContextMenu.add_item(\"Add tech animations (.prd)\", TECH1)
	%TreeContextMenu.add_item(\"Add tech animations as 2nd character\", TECH2)
	%TreeContextMenu.add_item(\"Add tech animations as 3rd character\", TECH3)
	
	if OS.get_name() == \"Linux\":
		converters_list = [\"./cc-model-converter-release\", \"./cc-model-converter-debug\"]
	elif OS.get_name() == \"Windows\":
		converters_list = [\"./cc-model-converter-release.exe\", \"./cc-model-converter-debug.exe\"]
	
	self.item_activated.connect(on_activated)
	self.item_selected.connect(on_select)
	load_zip(cdrom_path)
	
func _gui_input(event: InputEvent) -> void:
	if (
		event is InputEventMouseButton
		and event.button_index == MouseButton.MOUSE_BUTTON_RIGHT
		and event.is_pressed()
	):
		var treeItem = get_item_at_position(event.position)
		if treeItem != null:
			context_menu_for_path = itemPaths[treeItem]
			%TreeContextMenu.popup(Rect2i(event.global_position, Vector2i()))

func _on_context_menu_pressed(id: int) -> void:
	match id:
		OVERWORLD: requestGltf(last_loaded_path, last_loaded_extras + [\"--add-bin-anims\", context_menu_for_path])
		TECH1: requestGltf(last_loaded_path, last_loaded_extras + [\"--add-prd-anims\", context_menu_for_path, \"tech\"])
		TECH2: requestGltf(last_loaded_path, last_loaded_extras + [\"--add-prd-anims\", context_menu_for_path, \"tec1\"])
		TECH3: requestGltf(last_loaded_path, last_loaded_extras + [\"--add-prd-anims\", context_menu_for_path, \"tec2\"])
	
func _on_zip_open_press():
	var open = func(status: bool, paths: PackedStringArray, _filterIndex: int):
		if status:
			load_zip(paths[0])
	DisplayServer.file_dialog_show(
		\"Open cdrom.dat\", \".\", \"cdrom.dat\", false,
		DisplayServer.FILE_DIALOG_MODE_OPEN_FILE, [\"*.dat,*.zip\"],
		open
	)

func set_ancestry_color(item: TreeItem, color_index: int) -> void:
	var to_color = color_index
	if item in highlighted_already:
		to_color = max(highlighted_already[item], color_index)
	item.set_custom_color(0, HIGHLIGHT_COLORS[to_color])
	highlighted_already[item] = to_color
	var parent = item.get_parent()
	if parent != null:
		set_ancestry_color(parent, color_index)

func load_zip(zip_path: String):
	var cdrom := ZIPReader.new()
	var err := cdrom.open(zip_path)
	if err != OK:
		%PopupMessage.show_message(\"[color='red']Error opening zip file \" + zip_path + \"[/color]\")
		return
	cdrom_path = zip_path
	var zip_name = zip_path.split(\"/\", false)[-1]
	%ZipLabel.text = zip_name
	clear()
	var root := create_item()
	hide_root = true
	root.set_text(0, zip_name)
	var directoryItems := {}
	highlighted_already = {}
	itemPaths.clear()
	for file in cdrom.get_files():
		var path := file.split(\"/\", false)
		var parentItem = directoryItems.get(path.slice(0, path.size() - 1))
		var item := create_item(parentItem)
		item.set_text(0, path[path.size() - 1])
		if file.ends_with(\"/\"):
			directoryItems[path] = item
		for highlight in highlight_paths:
			var pattern = highlight[0]
			var color_index = highlight[1]
			if pattern.search(file) != null:
				set_ancestry_color(item, color_index)
		itemPaths[item] = file
	root.set_collapsed_recursive(true)
	root.collapsed = false

func on_select():
	#print(\"SELECTED: \", itemPaths[get_selected()])
	pass
	
func generateGltf(args: Array):
	var converter_path = get_most_recent_converter()
	print(\"Using converter: \", converter_path)
	LoadTimer.start(\"Generating gltf\")
	
	var child = OS.execute_with_pipe(converter_path, args, false)
	var stdio: FileAccess = child[\"stdio\"]
	var stderr: FileAccess = child[\"stderr\"]
	var out = PackedByteArray()
	while true:
		while true:
			var to_read = min(2048, stdio.get_length())
			if to_read > 0:
				var buffer = stdio.get_buffer(to_read)
				if stdio.get_error() == OK:
					out.append_array(buffer)
				else:
					print(stdio.get_error())
			else:
				break
		while true:
			var line = stderr.get_line()
			if stderr.get_error() == OK:
				print_rich(\"[color=blue]Converter: \", line)
			else:
				break
		if not OS.is_process_running(child[\"pid\"]) and stdio.get_length() == 0 and stderr.get_length() == 0:
			break
		await get_tree().process_frame
	var exitCode = OS.get_process_exit_code(child[\"pid\"])
	
	LoadTimer.stop()
	print(\"Exit code: \", exitCode)
	if exitCode == 0:
		return out
	else:
		return null
	
func requestGltf(to_load: String, extras: Array = []):
	if to_load.ends_with(\"/\"):
		to_load += to_load.split(\"/\")[-2] + \".obj\"
	var combat_model = to_load.begins_with(\"battle/\")
	var args = [\"--format=gltf\", \"--zip\", cdrom_path] + extras + [to_load]
	var generated = await generateGltf(args)
	if generated != null:
		last_loaded_path = to_load
		last_loaded_extras = extras
		%Preview.loadGltf(generated, combat_model)
		get_viewport().get_window().title = \"Viewing \" + last_loaded_path
	else:
		%PopupMessage.show_message(\"[color='orange']Couldn't load \" + to_load.split(\"/\", false)[-1] + \"[/color]\")

func on_activated():
	#print(\"ACTIVATED: \", get_selected().get_text(0))
	requestGltf(itemPaths[get_selected()])
"

[sub_resource type="GDScript" id="GDScript_je1mc"]
resource_name = "PopupMessageScript"
script/source = "extends RichTextLabel

var tween: Tween = null

func show_message(bbcode: String) -> void:
	print_rich(\"Message: \" + bbcode)
	text = bbcode
	if tween != null:
		tween.kill()
	tween = create_tween()
	tween.tween_property(self, \"visible\", true, 0.0)
	tween.tween_property(self, ^\"position:y\", 41.0, 0.10)
	tween.tween_interval(3.0)
	tween.tween_property(self, ^\"position:y\", -size.y - 5.0, 1.0)
	tween.tween_property(self, \"visible\", false, 0.0)
"

[sub_resource type="GDScript" id="GDScript_jhxm8"]
