script/source = "extends DirectionalLight3D

func _unhandled_input(event: InputEvent) -> void:
	if event is InputEventMouseMotion:
		if event.button_mask & MouseButtonMask.MOUSE_BUTTON_MASK_MIDDLE:
			rotation.y += event.screen_relative.x * 0.01
			# Rotating the sky makes me queasy :(
			# %WorldEnvironment.environment.sky_rotation.y += event.screen_relative.x * 0.01
"

