[sub_resource type="GDScript" id="GDScript_sgb71"]
resource_name = "CameraScript"
script/source = "extends Camera3D

@export var theta := 2.0 / 3.0 * PI
@export var phi := 1.0 / 6.0 * PI
@export var baseDistance := 5.0
@export var distanceLog: = 0.0

var focus := Vector3():
	get:
		return focus
	set(f):
		focus = f
		update_pos()

func _ready():
	%FocusCameraButton.pressed.connect(_on_camera_focus)
	update_pos()
	
func _on_camera_focus():
	var bounds = %Preview.calculateBounds()
	if bounds is AABB:
		var tween = create_tween()
		tween.set_ease(Tween.EASE_OUT)
		tween.set_trans(Tween.TRANS_QUAD)
		tween.tween_property(self, \"focus\", bounds.get_center(), 0.25)

func _unhandled_input(event: InputEvent) -> void:
	if get_viewport().get_camera_3d() != self: return
	if event is InputEventMouseMotion:
		if event.button_mask & MouseButtonMask.MOUSE_BUTTON_MASK_LEFT:
			theta = fposmod(theta + event.screen_relative.x * TAU / 750.0, TAU)
			phi = clamp(phi + event.screen_relative.y * TAU / 750.0, -0.49 * PI, 0.49 * PI)
		elif event.button_mask & MouseButtonMask.MOUSE_BUTTON_MASK_RIGHT:
			focus += -basis.x * event.screen_relative.x * 0.01 * pow(2.0, distanceLog)
			focus += basis.y * event.screen_relative.y * 0.01 * pow(2.0, distanceLog)
	elif event is InputEventMouseButton:
		if event.button_index == MouseButton.MOUSE_BUTTON_WHEEL_UP:
			distanceLog -= 0.2
		elif event.button_index == MouseButton.MOUSE_BUTTON_WHEEL_DOWN:
			distanceLog += 0.2
		elif event.button_index == MouseButton.MOUSE_BUTTON_LEFT:
			get_viewport().gui_release_focus()
	update_pos()
			
func update_pos():
	var distance = baseDistance * pow(2.0, distanceLog)
	position = focus + Vector3(cos(theta) * cos(phi), sin(phi), sin(theta) * cos(phi)) * distance
	look_at(focus)
"

